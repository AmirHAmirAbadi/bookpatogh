# Copy this file to `.env` (and NEVER commit the real .env) or export these
# as real environment variables before running the server.

# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# True for local development, False (or unset) once deployed
DJANGO_DEBUG=True

# Comma-separated list of hostnames/IPs this server will be reached at
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated list of frontend origins allowed to call this API
# (only used when DJANGO_DEBUG=False)
DJANGO_CORS_ALLOWED_ORIGINS=

# AI assistant (admin panel's "دستیار هوش مصنوعی" tab). Pick the provider
# here, then only fill in the API key for that one provider.
# gemini = Google Gemini (recommended: real free tier, good for SEO/blog writing)
# grok   = xAI Grok (real-time/X-flavored answers; free tier is very limited)
AI_PROVIDER=gemini

# Gemini key — create one at https://aistudio.google.com/app/apikey (free, no credit card)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Grok (xAI) key — create one at https://console.x.ai (only needed if AI_PROVIDER=grok)
XAI_API_KEY=
XAI_MODEL=grok-4.3

