# این فایل را روی سرور به نام `.env` کپی کن (کنار manage.py) — هرگز خودِ
# فایل .env واقعی را در گیت/جایی عمومی commit نکن.

# یک کلید تصادفی و امن (نمونه‌ی زیر فقط برای شروع تولید شده؛ بهتر است خودت
# دوباره با همین دستور یکی جدید بسازی و همین را جای آن بگذاری):
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=inDJKCWHHc_1yMLshp5bRl1go1C0gYIQaRt3kRxSeuc9WkR2PePgkv18Zqm2tXlvQ5g

# در پروداکشن همیشه False
DJANGO_DEBUG=False

# دامنه‌ی واقعی سایت (هر دو حالت با/بدون www را اضافه کن تا هر دو کار کنند؛
# ولی حتماً در Search Console یکی را به‌عنوان نسخه‌ی اصلی/canonical انتخاب کن)
DJANGO_ALLOWED_HOSTS=patoghebook.ir,www.patoghebook.ir

# چون فروشگاه تعاملی (/app/) و صفحات سئو هر دو از همین دامنه سرو می‌شوند،
# اگر جای دیگری (مثلاً یک اپ موبایل یا زیردامنه‌ی جدا) به API نیاز نداری
# این را خالی بگذار؛ در غیر این صورت آدرس آن را اینجا اضافه کن:
DJANGO_CORS_ALLOWED_ORIGINS=

# اگر ریورس‌پروکسی (nginx/Caddy) با SSL واقعی جلوی سرور است، این True درست
# است و تمام ترافیک http به https ریدایرکت می‌شود (توصیه‌شده برای سئو —
# گوگل نسخه‌ی https را ترجیح می‌دهد).
DJANGO_SECURE_SSL_REDIRECT=True

# دستیار هوش مصنوعی پنل ادمین (اختیاری برای سئو/تولید محتوای وبلاگ)
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
XAI_API_KEY=
XAI_MODEL=grok-4.3
